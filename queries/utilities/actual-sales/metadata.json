{
    "query": "ActualSales",
    "category": "utilities",
    "created": "2026-03-15",
    "author": "Claude",
    "status": "in-testing",
    "version": "1.0.0",
    "description": "Returns quarter-hour actual + projected product sales for all 96 trading slots (04:00→04:00) per Pod, including zero-sales slots for DataHub.",
    "tables": [
        "SalesFact",
        "SWCPeriod",
        "ProductMenu",
        "BO_MenuItem",
        "SalesHour"
    ],
    "parameters": [
        {
            "name": "SiteId",
            "type": "LongInteger",
            "expandInline": false
        },
        {
            "name": "BusDate",
            "type": "Date",
            "expandInline": false
        },
        {
            "name": "PodList",
            "type": "Text",
            "expandInline": true,
            "description": "Comma-separated Pod codes (e.g., 'CO','DT')"
        },
        {
            "name": "BrandType",
            "type": "Text",
            "expandInline": false
        }
    ],
    "outputColumns": [
        {
            "name": "Pod",
            "type": "Text"
        },
        {
            "name": "QtrHr",
            "type": "DateTime"
        },
        {
            "name": "ProductSales",
            "type": "Decimal"
        },
        {
            "name": "ProjectedProductSales",
            "type": "Decimal"
        }
    ]
}
